# backend/.env.example
# ====================================
# Controlled Anonymous Chat - Backend
# ====================================
REDIS_URL=redis://localhost:6379

# ====================================
# SERVER CONFIGURATION
# ====================================
# Port for FastAPI (Render/Railway will override with $PORT)
PORT=8000

# Host binding
HOST=0.0.0.0

# Environment mode
DEBUG=true

# ====================================
# RATE LIMITING & ABUSE PREVENTION
# ====================================
# Cooldown between queue attempts (seconds)
QUEUE_COOLDOWN_SECONDS=3

# Max requests per hour per device
SPAM_THRESHOLD=100

# Daily limit for specific gender filters (male/female)
DAILY_FILTER_LIMIT=50

# ====================================
# SECURITY & PRIVACY
# ====================================
# Max age of verification image (milliseconds)
# Rejects gallery uploads older than this
IMAGE_MAX_AGE_MS=10000

# Max reports before device is flagged
MAX_REPORTS_BEFORE_FLAG=3

# Room expiration time (seconds)
ROOM_EXPIRY_SECONDS=3600

# Queue expiration time (seconds)
QUEUE_EXPIRY_SECONDS=300

# ====================================
# CORS CONFIGURATION
# ====================================
# Allowed origins (comma-separated)
# Local: http://localhost:5173

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

